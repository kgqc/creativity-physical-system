{
  "name": "motexture-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"tsx watch server/index.ts\"",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node server-dist/index.js",
    "db:init": "tsx scripts/init-db.ts",
    "rh:inspect": "tsx scripts/inspect-runninghub-workflow.ts",
    "test": "tsx --test server/**/*.test.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
